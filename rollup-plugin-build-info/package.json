{
  "name": "@moreplease/rollup-plugin-build-info",
  "type": "module",
  "keywords": [
    "rollup",
    "rollup-plugin",
    "rolldown",
    "vite",
    "vite-plugin",
    "astro"
  ],
  "version": "0.0.9",
  "description": "import { commit, timestamp } from \"@moreplease/build-info\"",
  "tsup": {
    "entry": [
      "rollup-plugin-build-info.ts"
    ],
    "format": [
      "esm"
    ],
    "outDir": "build",
    "target": "node18",
    "splitting": false,
    "dts": true
  },
  "scripts": {
    "test": "tsc",
    "prepare": "tsup"
  },
  "files": [
    "LICENSE",
    "README.md",
    "build/*"
  ],
  "main": "build/rollup-plugin-build-info.js",
  "types": "build/rollup-plugin-build-info.d.ts",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
