{
  "name": "@moreplease/rollup-plugin-build-info",
  "version": "0.0.13",
  "type": "module",
  "keywords": [
    "rollup",
    "rollup-plugin",
    "rolldown",
    "vite",
    "vite-plugin",
    "astro"
  ],
  "description": "import { commit, timestamp } from \"@moreplease/build-info\"",
  "tsdown": {
    "entry": [
      "rollup-plugin-build-info.ts"
    ],
    "format": [
      "esm"
    ],
    "outDir": "build",
    "target": "node18",
    "splitting": false,
    "dts": true,
    "clean": false
  },
  "scripts": {
    "test": "tsc",
    "prepare": "tsdown"
  },
  "files": [
    "LICENSE",
    "README.md",
    "build/*"
  ],
  "main": "build/rollup-plugin-build-info.mjs",
  "types": "build/index.d.ts",
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3"
  }
}
