{
  "name": "runfig",
  "version": "0.1.7",
  "description": "Down with YAML and TOML! Generate your config files from code, the way nature intended",
  "keywords": [
    "configuration",
    "toml",
    "yaml"
  ],
  "license": "0BSD",
  "author": "Iain Merrick <iain@moreplease.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/more-please/more-stuff.git",
    "directory": "runfig"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "runfig": "dist/runfig.mjs"
  },
  "files": [
    "README.md",
    "LICENSE",
    "runfig.svg",
    "dist/*"
  ],
  "tsdown": {
    "entry": [
      "runfig.ts"
    ],
    "format": [
      "esm"
    ],
    "outDir": "dist",
    "target": "node22",
    "splitting": false
  },
  "scripts": {
    "format": "biome check --write --unsafe . && markdown-toc -i README.md",
    "test": "tsc",
    "prepare": "tsdown"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/mdast": "^4.0.4",
    "@types/node": "^26.1.1",
    "markdown-toc": "^1.2.0",
    "tsdown": "^0.22.4"
  },
  "dependencies": {
    "import-meta-resolve": "^4.2.0",
    "json5": "^2.2.3",
    "smol-toml": "^1.7.0",
    "walk-sync": "^4.0.2",
    "yaml": "^2.9.0"
  }
}
